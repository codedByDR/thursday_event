━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Custom React hook  useVoice({ onTranscript, onWakeWord })  that:
  • Continuous SpeechRecognition with interimResults=true.
  • Detects wake word "hi [assistant name]" → calls onWakeWord().
  • On final speech → calls onTranscript(text).
  • Exposes: { isListening, wakeDetected, transcript, supported, toggleListening, speak }
  • speak(text, lang):
      - Uses SpeechSynthesisUtterance.
      - pitch: 1.4, rate: 1.0, volume: 1.0.
      - Prefers female voice (matches: female|zira|samantha|karen|moira|tessa|fiona).
      - lang="ta" → "ta-IN",  lang="en" → "en-US".
  • Auto-restarts recognition on `onend` to stay continuous.
  • Graceful degradation: if API unsupported, exposed `supported=false`.
  • Cleanup on unmount.

