Add to main.py:
    @app.post("/api/agent", response_model=schemas.AgentResponse, tags=["Agent"])
    def run_agent(
        body: schemas.AgentRequest,
        current_user: models.User = Depends(auth_utils.get_current_user),
    ):
        state = {
            "user_input": body.user_input,
            "language": body.language,
            "intent": None, "request_data": None,
            "policy_valid": None, "policy_message": None,
            "result": None, "response_text": None,
            "user_id": current_user.id,
            "user_role": current_user.role,
        }
        result_state = agent_graph.invoke(state)
        return schemas.AgentResponse(
            intent        = result_state.get("intent", "general"),
            action        = result_state.get("result", {}).get("action", "general_response"),
            prefill       = result_state.get("result", {}).get("prefill"),
            response_text = result_state.get("response_text", ""),
            language      = result_state.get("language", "en"),
        )

